<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
  <name>PLG_SYSTEM_AIBOOST_INT_YOOTHEME</name>
  <author>AI Boost Team</author>
  <creationDate>June 2026</creationDate>
  <copyright>(C) 2025 AI Boost (aiboostnow.com). All rights reserved.</copyright>
  <license>GNU General Public License version 2 or later</license>
  <authorEmail>info@aiboostnow.com</authorEmail>
  <authorUrl>https://aiboostnow.com</authorUrl>
  <version>0.74.0</version>
  <description>AI Boost — YOOtheme Integration (free). Aligns per-page OpenGraph meta with the YOOtheme page title and description. FAQ/gallery/Event/Product/Organization Schema.org and sitemap clean-up are provided by the separate AI Boost — YOOtheme Pro add-on.</description>
  <php_minimum>8.1.0</php_minimum>
  <joomla_minimum>5.0.0</joomla_minimum>
  <namespace path="src">AiBoost\Plugin\System\AiBoostIntYootheme</namespace>
  <scriptfile>script.php</scriptfile>
  <updateservers>
    <server type="extension" priority="1" name="AI Boost for YOOtheme Updates">https://updates.aiboostnow.com/yootheme/pkg_aiboost_yootheme.xml?key={LICENSE_KEY}&amp;domain={SITE_DOMAIN}&amp;v={CURRENT_VERSION}</server>
  </updateservers>
  <files>
    <filename plugin="aiboost_int_yootheme">aiboost_int_yootheme.php</filename>
    <filename>script.php</filename>
    <folder>src</folder>
    <folder>language</folder>
  </files>
  <languages>
    <language tag="en-GB">language/en-GB/plg_system_aiboost_int_yootheme.ini</language>
    <language tag="en-GB">language/en-GB/plg_system_aiboost_int_yootheme.sys.ini</language>
  </languages>
  <config>
    <fields name="params">
      <fieldset name="basic" label="Basic">
        <field name="yootheme_meta_override" type="radio" label="Override OpenGraph from page meta"
               layout="joomla.form.field.radio.switcher" default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
      </fieldset>
    </fields>
  </config>
</extension>
