<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
  <name>PLG_SYSTEM_AIBOOST_FALANG</name>
  <author>AI Boost Team</author>
  <creationDate>May 2026</creationDate>
  <copyright>(C) 2025 AI Boost (aiboostnow.com). All rights reserved.</copyright>
  <license>GNU General Public License version 2 or later</license>
  <authorEmail>info@aiboostnow.com</authorEmail>
  <authorUrl>https://aiboostnow.com</authorUrl>
  <version>1.0.0</version>
  <description>PLG_SYSTEM_AIBOOST_FALANG_XML_DESCRIPTION</description>
  <php_minimum>8.1.0</php_minimum>
  <joomla_minimum>4.0.0</joomla_minimum>
  <namespace path="src">AiBoost\Plugin\System\AiBoostFalang</namespace>
  <files>
    <filename plugin="aiboost_falang">aiboost_falang.php</filename>
    <folder>src</folder>
    <folder>language</folder>
  </files>
  <languages>
    <language tag="en-GB">language/en-GB/plg_system_aiboost_falang.ini</language>
    <language tag="en-GB">language/en-GB/plg_system_aiboost_falang.sys.ini</language>
  </languages>
  <config>
    <fields name="params">
      <fieldset name="basic" label="PLG_SYSTEM_AIBOOST_FALANG_FIELDSET_BASIC">

        <field name="falang_hreflang_enabled"
               type="radio"
               label="PLG_SYSTEM_AIBOOST_FALANG_HREFLANG_ENABLED_LABEL"
               description="PLG_SYSTEM_AIBOOST_FALANG_HREFLANG_ENABLED_DESC"
               layout="joomla.form.field.radio.switcher"
               default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>

        <field name="falang_schema_translate"
               type="radio"
               label="PLG_SYSTEM_AIBOOST_FALANG_SCHEMA_TRANSLATE_LABEL"
               description="PLG_SYSTEM_AIBOOST_FALANG_SCHEMA_TRANSLATE_DESC"
               layout="joomla.form.field.radio.switcher"
               default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>

        <field name="falang_og_translate"
               type="radio"
               label="PLG_SYSTEM_AIBOOST_FALANG_OG_TRANSLATE_LABEL"
               description="PLG_SYSTEM_AIBOOST_FALANG_OG_TRANSLATE_DESC"
               layout="joomla.form.field.radio.switcher"
               default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>

        <field name="falang_hreflang_sitemap"
               type="radio"
               label="PLG_SYSTEM_AIBOOST_FALANG_HREFLANG_SITEMAP_LABEL"
               description="PLG_SYSTEM_AIBOOST_FALANG_HREFLANG_SITEMAP_DESC"
               layout="joomla.form.field.radio.switcher"
               default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>

        <field name="falang_primary_language"
               type="text"
               label="PLG_SYSTEM_AIBOOST_FALANG_PRIMARY_LANG_LABEL"
               description="PLG_SYSTEM_AIBOOST_FALANG_PRIMARY_LANG_DESC"
               default="en"
               size="10"/>

        <field name="falang_fallback_language"
               type="text"
               label="PLG_SYSTEM_AIBOOST_FALANG_FALLBACK_LANG_LABEL"
               description="PLG_SYSTEM_AIBOOST_FALANG_FALLBACK_LANG_DESC"
               default="en"
               size="10"/>

      </fieldset>
    </fields>
  </config>
</extension>
