<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
  <name>PLG_SYSTEM_AIBOOST_YOOTHEME</name>
  <author>AI Boost Team</author>
  <creationDate>May 2026</creationDate>
  <copyright>(C) 2025 AI Boost (aiboostnow.com). All rights reserved.</copyright>
  <license>GNU General Public License version 2 or later</license>
  <authorEmail>info@aiboostnow.com</authorEmail>
  <authorUrl>https://aiboostnow.com</authorUrl>
  <version>1.0.0</version>
  <description>PLG_SYSTEM_AIBOOST_YOOTHEME_XML_DESCRIPTION</description>
  <php_minimum>8.1.0</php_minimum>
  <joomla_minimum>4.0.0</joomla_minimum>
  <namespace path="src">AiBoost\Plugin\System\AiBoostYootheme</namespace>
  <files>
    <filename plugin="aiboost_yootheme">aiboost_yootheme.php</filename>
    <folder>src</folder>
    <folder>language</folder>
  </files>
  <languages>
    <language tag="en-GB">language/en-GB/plg_system_aiboost_yootheme.ini</language>
    <language tag="en-GB">language/en-GB/plg_system_aiboost_yootheme.sys.ini</language>
  </languages>
  <config>
    <fields name="params">
      <fieldset name="basic" label="PLG_SYSTEM_AIBOOST_YOOTHEME_FIELDSET_BASIC">

        <field name="yootheme_faq_enabled"
               type="radio"
               label="PLG_SYSTEM_AIBOOST_YOOTHEME_FAQ_ENABLED_LABEL"
               description="PLG_SYSTEM_AIBOOST_YOOTHEME_FAQ_ENABLED_DESC"
               layout="joomla.form.field.radio.switcher"
               default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>

        <field name="yootheme_accordion_selector"
               type="text"
               label="PLG_SYSTEM_AIBOOST_YOOTHEME_ACCORDION_SELECTOR_LABEL"
               description="PLG_SYSTEM_AIBOOST_YOOTHEME_ACCORDION_SELECTOR_DESC"
               default=".uk-accordion"
               size="60"/>

        <field name="yootheme_gallery_enabled"
               type="radio"
               label="PLG_SYSTEM_AIBOOST_YOOTHEME_GALLERY_ENABLED_LABEL"
               description="PLG_SYSTEM_AIBOOST_YOOTHEME_GALLERY_ENABLED_DESC"
               layout="joomla.form.field.radio.switcher"
               default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>

        <field name="yootheme_sitemap_exclude_builder"
               type="radio"
               label="PLG_SYSTEM_AIBOOST_YOOTHEME_SITEMAP_EXCLUDE_LABEL"
               description="PLG_SYSTEM_AIBOOST_YOOTHEME_SITEMAP_EXCLUDE_DESC"
               layout="joomla.form.field.radio.switcher"
               default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>

        <field name="yootheme_meta_override"
               type="radio"
               label="PLG_SYSTEM_AIBOOST_YOOTHEME_META_OVERRIDE_LABEL"
               description="PLG_SYSTEM_AIBOOST_YOOTHEME_META_OVERRIDE_DESC"
               layout="joomla.form.field.radio.switcher"
               default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>

      </fieldset>
    </fields>
  </config>
</extension>
