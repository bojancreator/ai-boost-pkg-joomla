<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
  <name>System - AI Boost Multilang Integration</name>
  <author>AI Boost Team</author>
  <creationDate>May 2026</creationDate>
  <copyright>(C) 2025 AI Boost (aiboostnow.com). All rights reserved.</copyright>
  <license>GNU General Public License version 2 or later</license>
  <authorEmail>info@aiboostnow.com</authorEmail>
  <authorUrl>https://aiboostnow.com</authorUrl>
  <version>0.58.0</version>
  <description>AI Boost — Multilang Integration. Bridges AI Boost SEO/AEO output with multilingual content (Falang or native Joomla): hreflang in head and sitemap, translated aliases, per-language Schema.org.</description>
  <php_minimum>8.1.0</php_minimum>
  <joomla_minimum>5.0.0</joomla_minimum>
  <namespace path="src">AiBoost\Plugin\System\AiBoostIntFalang</namespace>
  <scriptfile>script.php</scriptfile>
  <updateservers>
    <server type="extension" priority="1" name="AI Boost for Multilang Updates">https://updates.aiboostnow.com/multilang/pkg_aiboost_falang.xml?key={LICENSE_KEY}&amp;domain={SITE_DOMAIN}&amp;v={CURRENT_VERSION}</server>
  </updateservers>
  <files>
    <filename plugin="aiboost_int_falang">aiboost_int_falang.php</filename>
    <filename>script.php</filename>
    <folder>src</folder>
  </files>
  <config>
    <fields name="params">
      <fieldset name="basic" label="Basic">
        <field name="falang_hreflang_enabled" type="radio" label="Emit hreflang &lt;link&gt; in &lt;head&gt;"
               layout="joomla.form.field.radio.switcher" default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="falang_hreflang_sitemap" type="radio" label="Emit hreflang in sitemap"
               layout="joomla.form.field.radio.switcher" default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="falang_hreflang_mode" type="list" label="Hreflang source mode" default="auto">
          <option value="auto">Auto: Joomla native first, Falang fallback</option>
          <option value="joomla_native">Joomla native only</option>
          <option value="falang">Falang only</option>
        </field>
        <field name="falang_schema_translate" type="radio" label="Translate Schema.org per language"
               layout="joomla.form.field.radio.switcher" default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="falang_og_translate" type="radio" label="Translate OpenGraph per language"
               layout="joomla.form.field.radio.switcher" default="1">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="falang_primary_language" type="text" label="Primary language SEF" default="en" size="10"/>
      </fieldset>
    </fields>
  </config>
</extension>
