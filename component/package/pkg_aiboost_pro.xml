<?xml version="1.0" encoding="utf-8"?>
<extension type="package" version="3.9" method="upgrade">
    <name>AI Boost for Joomla — Pro Upgrade</name>
    <packagename>aiboost_pro</packagename>
    <author>AI Boost Team</author>
    <creationDate>June 2026</creationDate>
    <copyright>(C) 2025 AI Boost (aiboostnow.com). All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <authorEmail>info@aiboostnow.com</authorEmail>
    <authorUrl>https://aiboostnow.com</authorUrl>
    <version>0.45.0</version>
    <description>AI Boost for Joomla — Pro Upgrade. Installs the Pro plugins (Schema.org Pro, AEO Pro, Social/OpenGraph Pro, Hreflang Pro, Custom Code Pro) and the admin Health dashboard module on top of the AI Boost for Joomla base package, which must be installed first. Manage your licence under Components → AI Boost → License &amp; Updates.</description>
    <php_minimum>8.1.0</php_minimum>
    <joomla_minimum>5.0.0</joomla_minimum>
    <url>https://aiboostnow.com</url>
    <scriptfile>pkg_script_pro.php</scriptfile>
    <blockChildUninstall>true</blockChildUninstall>
    <!--
        No <updateservers> block for the Pro package in v1 BY DESIGN: Joomla's
        one-click update needs a direct, publicly downloadable ZIP URL, and Pro
        ZIPs are delivered through the licence-gated Lemon Squeezy customer
        portal instead. Pro customers are notified of new versions by e-mail and
        via their Lemon Squeezy "My Orders" page (see the release runbook in
        OPERATING.md). Revisit when a licence-aware update endpoint exists.
        The FREE base package DOES carry an update server (pkg_aiboost.xml).
    -->
    <files folder="packages">
        <file type="plugin"
              id="aiboost_schema_pro"
              group="system">plg_system_aiboost_schema_pro-0.41.0.zip</file>
        <file type="plugin"
              id="aiboost_aeo_pro"
              group="system">plg_system_aiboost_aeo_pro-0.41.0.zip</file>
        <file type="plugin"
              id="aiboost_social_pro"
              group="system">plg_system_aiboost_social_pro-0.41.0.zip</file>
        <file type="plugin"
              id="aiboost_hreflang_pro"
              group="system">plg_system_aiboost_hreflang_pro-0.41.0.zip</file>
        <file type="plugin"
              id="aiboost_code_pro"
              group="system">plg_system_aiboost_code_pro-0.41.0.zip</file>
        <file type="module"
              id="mod_aiboost_health"
              client="administrator">mod_aiboost_health-0.41.0.zip</file>
    </files>
</extension>
