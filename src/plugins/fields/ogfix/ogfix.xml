<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="fields" method="upgrade" version="4.0">
    <name>PLG_FIELDS_OGFIX</name>
    <author>JoomlaBoost Team</author>
    <creationDate>2025-01-25</creationDate>
    <copyright>Copyright (C) 2025 JoomlaBoost. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <authorEmail>support@joomlaboost.com</authorEmail>
    <version>0.1.104</version>
    <description>PLG_FIELDS_OGFIX_DESCRIPTION</description>

    <namespace path="src">Joomla\Plugin\Fields\Ogfix</namespace>

    <files>
        <folder plugin="ogfix">src</folder>
    </files>

    <languages folder="language">
        <language tag="en-GB">en-GB/plg_fields_ogfix.ini</language>
        <language tag="en-GB">en-GB/plg_fields_ogfix.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="enabled_contexts"
                    type="textarea"
                    default="com_content.article"
                    label="PLG_FIELDS_OGFIX_ENABLED_CONTEXTS_LABEL"
                    description="PLG_FIELDS_OGFIX_ENABLED_CONTEXTS_DESC"
                    rows="3"
                    filter="raw"
                />

                <field
                    name="target_fields"
                    type="textarea"
                    default="custom_og_image"
                    label="PLG_FIELDS_OGFIX_TARGET_FIELDS_LABEL"
                    description="PLG_FIELDS_OGFIX_TARGET_FIELDS_DESC"
                    rows="3"
                    filter="raw"
                />

                <field
                    name="debug_logging"
                    type="radio"
                    default="0"
                    label="PLG_FIELDS_OGFIX_DEBUG_LOGGING_LABEL"
                    description="PLG_FIELDS_OGFIX_DEBUG_LOGGING_DESC"
                    class="btn-group btn-group-yesno"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
