<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
  <name>JoomlaBoost - Universal SEO &amp; Performance Plugin</name>
  <author>JoomlaBoost Team</author>
  <creationDate>February 27, 2026 12:49</creationDate>
  <copyright>(C) 2025 JoomlaBoost. All rights reserved.</copyright>
  <license>GNU General Public License version 2 or later</license>
  <authorEmail>info@joomlaboost.com</authorEmail>
  <authorUrl>https://joomlaboost.com</authorUrl>
  <version>0.8.0</version>
  <description>PLG_SYSTEM_JOOMLABOOST_XML_DESCRIPTION</description>
  <!-- System Requirements -->
  <php_minimum>8.1.0</php_minimum>
  <joomla_minimum>4.0.0</joomla_minimum>
  <joomla_maximum>6.9999.9999</joomla_maximum>
  <scriptfile>script.php</scriptfile>
  <files>
    <filename plugin="joomlaboost">joomlaboost.php</filename>
    <folder>language</folder>
    <folder>src</folder>
    <folder>media</folder>
    <folder>sql</folder>
  </files>
  <!-- Custom Form Fields -->
  <addonfields path="src/Field">
    <field>MultiLangTextField</field>
    <field>MultiLangTextarea</field>
  </addonfields>
  <!-- Media Assets -->
  <media folder="media" destination="plg_system_joomlaboost">
    <folder>js</folder>
    <folder>css</folder>
    <filename>admin.css</filename>
    <filename>multilang-fields.css</filename>
    <filename>joomla.asset.json</filename>
  </media>
  <languages>
    <language tag="en-GB">language/en-GB/plg_system_joomlaboost.ini</language>
    <language tag="en-GB">language/en-GB/plg_system_joomlaboost.sys.ini</language>
  </languages>
  <config>
    <fields name="params">
      <fieldset name="basic" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_BASIC">
        <!-- Domain Detection -->
        <field name="auto_domain_detection" type="radio" label="PLG_SYSTEM_JOOMLABOOST_AUTO_DOMAIN_DETECTION_LABEL" description="PLG_SYSTEM_JOOMLABOOST_AUTO_DOMAIN_DETECTION_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="manual_domain" type="url" label="PLG_SYSTEM_JOOMLABOOST_MANUAL_DOMAIN_LABEL" description="PLG_SYSTEM_JOOMLABOOST_MANUAL_DOMAIN_DESC" default="" showon="auto_domain_detection:0" />
        <!-- SEO Features -->
        <field name="enable_robots" type="radio" label="PLG_SYSTEM_JOOMLABOOST_ROBOTS_LABEL" description="PLG_SYSTEM_JOOMLABOOST_ROBOTS_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="robots_auto_sync" type="radio" label="Auto-Sync robots.txt File" description="Automatically update physical robots.txt file to match plugin rules. Recommended to prevent conflicts with Joomla updates." default="1" class="btn-group btn-group-yesno" showon="enable_robots:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="enable_hreflang" type="radio" label="PLG_SYSTEM_JOOMLABOOST_HREFLANG_LABEL" description="PLG_SYSTEM_JOOMLABOOST_HREFLANG_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
      </fieldset>
      <!-- Sitemap Configuration -->
      <fieldset name="sitemap" label="Sitemap">
        <field name="enable_sitemap" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SITEMAP_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SITEMAP_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <!-- Content Types -->
        <field name="sitemap_spacer_types" type="spacer" label="Content Types" class="text-primary" showon="enable_sitemap:1" />
        <field name="sitemap_include_articles" type="radio" label="Include Articles" description="Add published articles" default="1" class="btn-group btn-group-yesno" showon="enable_sitemap:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="sitemap_include_categories" type="radio" label="Include Categories" description="Add category pages" default="1" class="btn-group btn-group-yesno" showon="enable_sitemap:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="sitemap_include_menu" type="radio" label="Include Menu Items" description="Add menu items" default="0" class="btn-group btn-group-yesno" showon="enable_sitemap:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="sitemap_menu_depth" type="list" label="Menu Depth" description="Control menu hierarchy depth (0 = unlimited, 1 = top level only, 2 = two levels)" default="0" showon="enable_sitemap:1,sitemap_include_menu:1">
          <option value="0">Unlimited (All levels)</option>
          <option value="1">Level 1 only</option>
          <option value="2">Levels 1-2</option>
        </field>
        <field name="sitemap_menu_types" type="sql" label="Select Menus" description="Choose which menus to include (empty = all menus)" default="" multiple="true" showon="enable_sitemap:1,sitemap_include_menu:1" query="SELECT menutype AS value, title FROM #__menu_types ORDER BY title" key_field="value" value_field="title" />
        <!-- Article Options -->
        <field name="sitemap_spacer_articles" type="spacer" label="Article Options" class="text-info" showon="enable_sitemap:1,sitemap_include_articles:1" />
        <field name="sitemap_article_categories" type="category" extension="com_content" multiple="true" label="Select Categories" description="Choose categories (empty = all)" default="" showon="enable_sitemap:1,sitemap_include_articles:1" />
        <field name="sitemap_exclude_ids" type="textarea" label="Exclude Article IDs" description="Comma-separated IDs (e.g., 1,5,12)" default="" rows="2" cols="40" showon="enable_sitemap:1,sitemap_include_articles:1" />
        <field name="sitemap_max_articles" type="number" label="Max Articles" description="0 = unlimited" default="0" min="0" max="10000" step="10" showon="enable_sitemap:1,sitemap_include_articles:1" />
        <!-- Multilingual -->
        <field name="sitemap_spacer_multilang" type="spacer" label="Multilingual (hreflang)" class="text-warning" showon="enable_sitemap:1" />
        <field name="sitemap_hreflang" type="radio" label="Multilingual Sitemap" description="Add xhtml:link hreflang alternate tags for each URL in all active languages. Requires Joomla Language Filter plugin active. Works with Falang and native Joomla multilingual. Default: OFF." default="0" class="btn-group btn-group-yesno" showon="enable_sitemap:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <!-- SEO Priority -->

        <field name="sitemap_spacer_seo" type="spacer" label="SEO Priority" class="text-success" showon="enable_sitemap:1" />
        <field name="sitemap_priority_articles" type="list" label="Articles Priority" default="0.8" showon="enable_sitemap:1,sitemap_include_articles:1">
          <option value="1.0">1.0 (Highest)</option>
          <option value="0.8">0.8 (Recommended)</option>
          <option value="0.5">0.5 (Medium)</option>
        </field>
        <field name="sitemap_priority_categories" type="list" label="Categories Priority" default="0.7" showon="enable_sitemap:1,sitemap_include_categories:1">
          <option value="1.0">1.0</option>
          <option value="0.7">0.7 (Recommended)</option>
          <option value="0.5">0.5</option>
        </field>
        <field name="sitemap_priority_menu" type="list" label="Menu Priority" default="0.6" showon="enable_sitemap:1,sitemap_include_menu:1">
          <option value="1.0">1.0</option>
          <option value="0.6">0.6 (Recommended)</option>
          <option value="0.5">0.5</option>
        </field>
        <!-- Change Frequency -->
        <field name="sitemap_spacer_changefreq" type="spacer" label="Update Frequency" class="text-warning" showon="enable_sitemap:1" />
        <field name="sitemap_changefreq_articles" type="list" label="Articles Frequency" default="weekly" showon="enable_sitemap:1,sitemap_include_articles:1">
          <option value="daily">Daily</option>
          <option value="weekly">Weekly (Recommended)</option>
          <option value="monthly">Monthly</option>
        </field>
        <field name="sitemap_changefreq_categories" type="list" label="Categories Frequency" default="weekly" showon="enable_sitemap:1,sitemap_include_categories:1">
          <option value="daily">Daily</option>
          <option value="weekly">Weekly (Recommended)</option>
          <option value="monthly">Monthly</option>
        </field>
        <field name="sitemap_changefreq_menu" type="list" label="Menu Frequency" default="monthly" showon="enable_sitemap:1,sitemap_include_menu:1">
          <option value="weekly">Weekly</option>
          <option value="monthly">Monthly (Recommended)</option>
        </field>
      </fieldset>
      <!-- OpenGraph Configuration -->
      <fieldset name="opengraph" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_OPENGRAPH">
        <field name="enable_opengraph" type="radio" label="PLG_SYSTEM_JOOMLABOOST_OPENGRAPH_LABEL" description="PLG_SYSTEM_JOOMLABOOST_OPENGRAPH_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <!-- OpenGraph Site Name -->
        <field name="og_site_name" type="text" label="PLG_SYSTEM_JOOMLABOOST_OG_SITE_NAME_LABEL" description="PLG_SYSTEM_JOOMLABOOST_OG_SITE_NAME_DESC" default="" hint="OffRoad Serbia" showon="enable_opengraph:1" />
        <!-- OpenGraph Default Image -->
        <field name="og_image" type="media" label="PLG_SYSTEM_JOOMLABOOST_OG_IMAGE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_OG_IMAGE_DESC" default="" directory="images" showon="enable_opengraph:1" />
        <!-- Per-Article OpenGraph Override Notice -->
        <field name="og_override_note" type="note" label="📝 Per-Article OpenGraph Overrides" description="To override OpenGraph meta tags for specific articles, use Joomla Custom Fields (com_fields). Create fields named: &lt;strong&gt;custom_og_image&lt;/strong&gt;, &lt;strong&gt;custom_og_title&lt;/strong&gt;, &lt;strong&gt;custom_og_description&lt;/strong&gt;. Priority: Custom Fields → Featured Image → Global Config." class="alert alert-info" showon="enable_opengraph:1" />
      </fieldset>
      <!-- Schema.org Configuration -->
      <fieldset name="schema" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_SCHEMA">
        <field name="enable_schema" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <!-- Multi-Language Organization Name -->
        <field name="schema_multilang_spacer" type="spacer" label="Multi-Language Configuration" class="text-primary" showon="enable_schema:1" />
        
        <!-- Language Selector Dropdown -->
        <field name="schema_lang_selector"
               type="list"
               label="View Language Fields"
               description="Select which language fields to display below"
               default="en"
               showon="enable_schema:1">
          <option value="all">🌍 All Languages</option>
          <option value="en">🇬🇧 English Only</option>
          <option value="sr">🇷🇸 Српски Only</option>
          <option value="ru">🇷🇺 Русский Only</option>
        </field>
        
        <!-- Organization Name (Multi-Language) -->
        <field name="org_name_en"
               type="text"
               label="Organization Name (English)"
               description="Schema.org organization name in English"
               hint="e.g., Off-Road Serbia"
               class="form-control"
               showon="enable_schema:1[AND]schema_lang_selector:all,en" />

        <field name="org_name_sr"
               type="text"
               label="Organization Name (Српски)"
               description="Schema.org organization name in Serbian"
               hint="e.g., Off-Road Serbia"
               class="form-control"
               showon="enable_schema:1[AND]schema_lang_selector:all,sr" />

        <field name="org_name_ru"
               type="text"
               label="Organization Name (Русский)"
               description="Schema.org organization name in Russian"
               hint="e.g., Off-Road Serbia"
               class="form-control"
               showon="enable_schema:1[AND]schema_lang_selector:all,ru" />
        <!-- Organization Logo -->
        <field name="org_logo" type="media" label="PLG_SYSTEM_JOOMLABOOST_ORG_LOGO_LABEL" description="PLG_SYSTEM_JOOMLABOOST_ORG_LOGO_DESC" default="" directory="images" showon="enable_schema:1" />
        <!-- Schema.org Type Selection -->
        <field name="schema_type" type="list" label="Schema.org Organization Type" description="Choose the type of schema for your organization. Auto-detect uses site characteristics, LocalBusiness includes geo/address data, Hotel includes accommodation-specific fields, Organization is generic." default="auto" showon="enable_schema:1">
          <option value="auto">Auto-detect (recommended)</option>
          <option value="organization">Organization (generic)</option>
          <option value="localbusiness">LocalBusiness (physical location)</option>
          <option value="hotel">Hotel (accommodation)</option>
        </field>
        <!-- Organization Contact Information (All Types) -->
        <field name="schema_url" type="url" label="Organization URL" description="Official website URL (auto-detected if empty)" default="" showon="enable_schema:1" hint="https://example.com" />
        <!-- Multi-Language Description -->
        <field name="schema_description_en"
               type="textarea"
               label="Organization Description (English)"
               description="Short description of your organization in English (1-2 sentences)"
               hint="e.g., Professional off-road tours and 4x4 adventures in Serbia"
               class="form-control"
               rows="3"
               showon="enable_schema:1[AND]schema_lang_selector:all,en" />

        <field name="schema_description_sr"
               type="textarea"
               label="Organization Description (Српски)"
               description="Short description of your organization in Serbian (1-2 sentences)"
               hint="e.g., Professional off-road tours and 4x4 adventures in Serbia"
               class="form-control"
               rows="3"
               showon="enable_schema:1[AND]schema_lang_selector:all,sr" />

        <field name="schema_description_ru"
               type="textarea"
               label="Organization Description (Русский)"
               description="Short description of your organization in Russian (1-2 sentences)"
               hint="e.g., Professional off-road tours and 4x4 adventures in Serbia"
               class="form-control"
               rows="3"
               showon="enable_schema:1[AND]schema_lang_selector:all,ru" />
        <field name="schema_telephone" type="tel" label="Telephone" description="Organization contact telephone number" default="" showon="enable_schema:1" hint="+381 11 1234567" />
        <field name="schema_email" type="email" label="Email" description="Organization contact email" default="" showon="enable_schema:1" hint="info@example.com" />
        <!-- Social Media Links (sameAs) -->
        <field name="schema_social_spacer" type="spacer" label="Social Media Links" class="text-primary" />
        <field name="schema_social_facebook" type="url" label="Facebook URL" description="Full URL to your Facebook page" default="" hint="https://www.facebook.com/yourpage" />
        <field name="schema_social_instagram" type="url" label="Instagram URL" description="Full URL to your Instagram profile" default="" hint="https://www.instagram.com/yourprofile" />
        <field name="schema_social_youtube" type="url" label="YouTube URL" description="Full URL to your YouTube channel" default="" hint="https://www.youtube.com/c/yourchannel" />
        <field name="schema_social_twitter" type="url" label="Twitter/X URL" description="Full URL to your Twitter/X profile" default="" hint="https://twitter.com/yourhandle" />
        <field name="schema_social_linkedin" type="url" label="LinkedIn URL" description="Full URL to your LinkedIn page" default="" hint="https://www.linkedin.com/company/yourcompany" />
        <!-- LocalBusiness/Hotel Geo Coordinates -->
        <field name="schema_latitude" type="text" label="Latitude" description="Geographic latitude (e.g., 44.0165)" default="" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="44.0165" />
        <field name="schema_longitude" type="text" label="Longitude" description="Geographic longitude (e.g., 21.0059)" default="" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="21.0059" />
        <!-- LocalBusiness/Hotel Address -->
        <field name="schema_address_country" type="text" label="Country Code" description="ISO 3166-1 alpha-2 country code (e.g., RS, US, GB)" default="" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="RS" />
        <field name="schema_address_locality" type="text" label="City/Locality" description="City or locality name" default="" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="Belgrade" />
        <field name="schema_address_street" type="text" label="Street Address" description="Full street address including number" default="" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="Knez Mihajlova 1" />
        <field name="schema_address_zip" type="text" label="Postal Code" description="ZIP or postal code" default="" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="11000" />
        <field name="schema_phone" type="text" label="Phone Number" description="Business phone in international format" default="" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="+381111234567" />
        <field name="schema_email" type="email" label="Email Address" description="Business contact email" default="" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" />
        <!-- LocalBusiness/Hotel Service Details -->
        <field name="schema_price_range" type="list" label="Price Range" description="Price range indicator for services" default="$$" showon="enable_schema:1[AND]schema_type:localbusiness,hotel">
          <option value="$">$ (Budget)</option>
          <option value="$$">$$ (Moderate)</option>
          <option value="$$$">$$$ (Expensive)</option>
          <option value="$$$$">$$$$ (Very Expensive)</option>
        </field>
        <field name="schema_opening_hours" type="text" label="Opening Hours" description="Business opening hours (e.g., Mo-Su 09:00-18:00)" default="Mo-Su 09:00-18:00" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="Mo-Su 09:00-18:00" />
        <!-- Hotel-Specific Fields -->
        <field name="schema_hotel_star_rating" type="list" label="Star Rating" description="Hotel star rating (1-5 stars)" default="3" showon="enable_schema:1[AND]schema_type:hotel">
          <option value="1">1 Star</option>
          <option value="2">2 Stars</option>
          <option value="3">3 Stars</option>
          <option value="4">4 Stars</option>
          <option value="5">5 Stars</option>
        </field>
        <field name="schema_hotel_checkin_time" type="text" label="Check-in Time" description="Standard check-in time (24h format)" default="14:00" showon="enable_schema:1[AND]schema_type:hotel" hint="14:00" />
        <field name="schema_hotel_checkout_time" type="text" label="Check-out Time" description="Standard check-out time (24h format)" default="12:00" showon="enable_schema:1[AND]schema_type:hotel" hint="12:00" />
        <field name="schema_hotel_pets_allowed" type="radio" label="Pets Allowed" description="Are pets allowed in the hotel?" default="0" class="btn-group btn-group-yesno" showon="enable_schema:1[AND]schema_type:hotel">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <!-- Separator -->
        <field name="separator_faq" type="spacer" label="FAQ Schema Support" class="text" />
        <!-- FAQ Schema -->
        <field name="faq_schema_enabled" type="radio" label="PLG_SYSTEM_JOOMLABOOST_FAQ_SCHEMA_LABEL" description="PLG_SYSTEM_JOOMLABOOST_FAQ_SCHEMA_DESC" default="1" class="btn-group btn-group-yesno" showon="enable_schema:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="faq_auto_detect" type="radio" label="Auto-Detect FAQ from Content" description="Automatically detect Q&amp;A pairs from article content. Looks for description lists (&lt;dl&gt;/&lt;dt&gt;/&lt;dd&gt;) and headings (&lt;h3&gt;/&lt;h4&gt; followed by &lt;p&gt;). Generates FAQPage JSON-LD per page. Recommended: YES." default="1" class="btn-group btn-group-yesno" showon="enable_schema:1,faq_schema_enabled:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <!-- Q&A Management (Manual FAQ Input) -->
        <field name="separator_qa_management" type="spacer" label="Q&amp;A Management (Manual FAQ Input)" class="text-primary" showon="enable_schema:1,faq_schema_enabled:1" />
        <field name="enable_manual_faqs" type="radio" label="Enable Manual FAQs" description="Add custom FAQ items via JSON editor below. These will be merged with auto-detected FAQs." default="0" class="btn-group btn-group-yesno" showon="enable_schema:1,faq_schema_enabled:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="faq_display_mode" type="list" label="FAQ Display Mode" description="Choose how to combine manual and auto-detected FAQs" default="manual_first" showon="enable_schema:1,faq_schema_enabled:1,enable_manual_faqs:1">
          <option value="manual_only">Manual FAQs Only</option>
          <option value="auto_only">Auto-detected Only</option>
          <option value="manual_first">Manual First, then Auto-detected</option>
          <option value="auto_first">Auto-detected First, then Manual</option>
        </field>
        <!-- Multi-Language Manual FAQs -->
        <field name="faq_lang_selector"
               type="list"
               label="FAQ Language - View Fields"
               description="Select which language FAQ fields to display below"
               default="en"
               showon="enable_schema:1,faq_schema_enabled:1,enable_manual_faqs:1">
          <option value="all">🌍 All Languages</option>
          <option value="en">🇬🇧 English Only</option>
          <option value="sr">🇷🇸 Српски Only</option>
          <option value="ru">🇷🇺 Русский Only</option>
        </field>
        <field name="manual_faqs_en"
               type="textarea"
               label="Manual FAQ Items (English)"
               description="FAQ items in JSON format for English. Format: [{&quot;question&quot;: &quot;Q?&quot;, &quot;answer&quot;: &quot;A.&quot;}]"
               default=""
               rows="8"
               cols="80"
               filter="raw"
               class="input-xxlarge"
               showon="enable_schema:1,faq_schema_enabled:1,enable_manual_faqs:1[AND]faq_lang_selector:all,en" />
        <field name="manual_faqs_sr"
               type="textarea"
               label="Manual FAQ Items (Српски)"
               description="FAQ stavke u JSON formatu za srpski jezik. Ako je prazno, koristi se engleski."
               default=""
               rows="8"
               cols="80"
               filter="raw"
               class="input-xxlarge"
               showon="enable_schema:1,faq_schema_enabled:1,enable_manual_faqs:1[AND]faq_lang_selector:all,sr" />
        <field name="manual_faqs_ru"
               type="textarea"
               label="Manual FAQ Items (Русский)"
               description="Элементы FAQ в формате JSON для русского языка. Если пусто, используется английский."
               default=""
               rows="8"
               cols="80"
               filter="raw"
               class="input-xxlarge"
               showon="enable_schema:1,faq_schema_enabled:1,enable_manual_faqs:1[AND]faq_lang_selector:all,ru" />
        <field name="faq_json_help" type="note" label="JSON Format Help" description="Format: Array of objects. Example: [{\&quot;question\&quot;: \&quot;What?\&quot;, \&quot;answer\&quot;: \&quot;This!\&quot;}]. Note: Auto-detected FAQs from article content are already translated by Falang automatically." class="alert alert-info" showon="enable_schema:1,faq_schema_enabled:1,enable_manual_faqs:1" />
      </fieldset>
      <fieldset name="google" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_GOOGLE">
        <!-- Google Search Console Verification -->
        <field name="enable_google_verification" type="radio" label="PLG_SYSTEM_JOOMLABOOST_GOOGLE_VERIFICATION_LABEL" description="PLG_SYSTEM_JOOMLABOOST_GOOGLE_VERIFICATION_DESC" default="0" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="gsc_verification_meta" type="text" label="PLG_SYSTEM_JOOMLABOOST_GSC_VERIFICATION_META_LABEL" description="PLG_SYSTEM_JOOMLABOOST_GSC_VERIFICATION_META_DESC" default="" showon="enable_google_verification:1" />
        <field name="gsc_additional_html" type="textarea" label="PLG_SYSTEM_JOOMLABOOST_GSC_ADDITIONAL_HTML_LABEL" description="PLG_SYSTEM_JOOMLABOOST_GSC_ADDITIONAL_HTML_DESC" default="" rows="5" cols="80" showon="enable_google_verification:1" />
        <!-- Google Analytics 4 -->
        <field name="enable_ga4" type="radio" label="PLG_SYSTEM_JOOMLABOOST_GA4_LABEL" description="PLG_SYSTEM_JOOMLABOOST_GA4_DESC" default="0" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="ga4_measurement_id" type="text" label="PLG_SYSTEM_JOOMLABOOST_GA4_MEASUREMENT_ID_LABEL" description="PLG_SYSTEM_JOOMLABOOST_GA4_MEASUREMENT_ID_DESC" default="" hint="G-XXXXXXXXXX" showon="enable_ga4:1" />
        <!-- GA4 GDPR Consent Mode -->
        <field name="ga4_consent_mode" type="list" label="GDPR Consent Mode" description="YooTheme Pro 5: adds data-category attributes so YooTheme consent manager blocks this script until user accepts. GTM: skip direct GA4 injection, let GTM handle it with its own consent settings. None: inject directly without consent (legacy)." default="none" showon="enable_ga4:1">
          <option value="none">None (Direct inject - no GDPR)</option>
          <option value="yootheme">YooTheme Pro 5 Consent Manager</option>
          <option value="gtm">Via GTM (skip direct GA4)</option>
        </field>
        <!-- Google Tag Manager -->
        <field name="enable_gtm" type="radio" label="PLG_SYSTEM_JOOMLABOOST_GTM_LABEL" description="PLG_SYSTEM_JOOMLABOOST_GTM_DESC" default="0" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="gtm_container_id" type="text" label="PLG_SYSTEM_JOOMLABOOST_GTM_CONTAINER_ID_LABEL" description="PLG_SYSTEM_JOOMLABOOST_GTM_CONTAINER_ID_DESC" default="" hint="GTM-XXXXXXX" showon="enable_gtm:1" />
      </fieldset>
      <fieldset name="facebook" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_FACEBOOK">
        <!-- Meta Pixel (Facebook Pixel) -->
        <field name="enable_meta_pixel" type="radio" label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_LABEL" description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_DESC" default="0" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="meta_pixel_id" type="text" label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_ID_LABEL" description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_ID_DESC" default="" hint="123456789012345" showon="enable_meta_pixel:1" />
        <!-- Meta Pixel GDPR Consent Mode -->
        <field name="pixel_consent_mode" type="list" label="GDPR Consent Mode" description="YooTheme Pro 5: wraps pixel script with data-category='marketing' so YooTheme consent manager blocks it until user accepts marketing cookies. None: inject directly without consent (legacy)." default="none" showon="enable_meta_pixel:1">
          <option value="none">None (Direct inject - no GDPR)</option>
          <option value="yootheme">YooTheme Pro 5 Consent Manager</option>
        </field>
        <!-- Facebook Domain Verification -->
        <field name="fb_domain_verification" type="text" label="Facebook Domain Verification Code" description="Enter the verification code from Facebook Business Manager (without the meta tag markup)" default="" hint="abcdefgh1234567890" showon="enable_meta_pixel:1" />
        <!-- Meta Pixel Custom Events -->
        <field name="meta_pixel_events_header" type="note" label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_EVENTS_HEADER" description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_EVENTS_HEADER_DESC" showon="enable_meta_pixel:1" />
        <field name="meta_pixel_track_purchase" type="radio" label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_PURCHASE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_PURCHASE_DESC" default="0" class="btn-group btn-group-yesno" showon="enable_meta_pixel:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="meta_pixel_track_add_to_cart" type="radio" label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_ADD_TO_CART_LABEL" description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_ADD_TO_CART_DESC" default="0" class="btn-group btn-group-yesno" showon="enable_meta_pixel:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="meta_pixel_track_contact" type="radio" label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_CONTACT_LABEL" description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_CONTACT_DESC" default="0" class="btn-group btn-group-yesno" showon="enable_meta_pixel:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="meta_pixel_track_lead" type="radio" label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_LEAD_LABEL" description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_LEAD_DESC" default="0" class="btn-group btn-group-yesno" showon="enable_meta_pixel:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
      </fieldset>
      <fieldset name="performance" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_PERFORMANCE">
        <field name="enable_caching" type="radio" label="PLG_SYSTEM_JOOMLABOOST_CACHING_LABEL" description="PLG_SYSTEM_JOOMLABOOST_CACHING_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="cache_ttl" type="number" label="PLG_SYSTEM_JOOMLABOOST_CACHE_TTL_LABEL" description="PLG_SYSTEM_JOOMLABOOST_CACHE_TTL_DESC" default="3600" min="60" max="86400" showon="enable_caching:1" />
      </fieldset>
      <fieldset name="debug" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_DEBUG">
        <field name="debug_mode" type="radio" label="PLG_SYSTEM_JOOMLABOOST_DEBUG_MODE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_DEBUG_MODE_DESC" default="0" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="debug_wrap_markers" type="radio" label="PLG_SYSTEM_JOOMLABOOST_DEBUG_WRAP_MARKERS_LABEL" description="PLG_SYSTEM_JOOMLABOOST_DEBUG_WRAP_MARKERS_DESC" default="0" class="btn-group btn-group-yesno" showon="debug_mode:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="show_staging_badge" type="radio" label="PLG_SYSTEM_JOOMLABOOST_STAGING_BADGE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_STAGING_BADGE_DESC" default="0" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
      </fieldset>
    </fields>
  </config>
  <updateservers>
    <server type="extension" priority="1" name="JoomlaBoost Update Server">
            https://updates.joomlaboost.com/joomlaboost.xml
        </server>
  </updateservers>
</extension>