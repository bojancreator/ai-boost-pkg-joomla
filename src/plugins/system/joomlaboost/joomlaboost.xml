<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>JoomlaBoost - Universal SEO &amp; Performance Plugin</name>
    <author>JoomlaBoost Team</author>
    <creationDate>November 2025</creationDate>
    <copyright>(C) 2025 JoomlaBoost. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <authorEmail>info@joomlaboost.com</authorEmail>
    <authorUrl>https://joomlaboost.com</authorUrl>
    <version>0.1.37</version>
    <description>PLG_SYSTEM_JOOMLABOOST_XML_DESCRIPTION</description>

    <!-- System Requirements -->
    <php_minimum>8.1.0</php_minimum>
    <joomla_minimum>4.0.0</joomla_minimum>
    <joomla_maximum>6.9999.9999</joomla_maximum>

    <files>
        <filename plugin="joomlaboost">joomlaboost.php</filename>
        <filename>joomlaboost-minimal.php</filename>
        <filename>script.php</filename>
        <folder>language</folder>
        <folder>src</folder>
        <folder>media</folder>
    </files>

    <scriptfile>script.php</scriptfile>

    <languages>
        <language tag="en-GB">language/en-GB/plg_system_joomlaboost.ini</language>
        <language tag="en-GB">language/en-GB/plg_system_joomlaboost.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_BASIC">

                <!-- Domain Detection -->
                <field name="auto_domain_detection"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_AUTO_DOMAIN_DETECTION_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_AUTO_DOMAIN_DETECTION_DESC"
                       default="1"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="manual_domain"
                       type="url"
                       label="PLG_SYSTEM_JOOMLABOOST_MANUAL_DOMAIN_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_MANUAL_DOMAIN_DESC"
                       default=""
                       showon="auto_domain_detection:0"/>

                <!-- SEO Features -->
                <field name="enable_robots"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_ROBOTS_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_ROBOTS_DESC"
                       default="1"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="enable_sitemap"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_SITEMAP_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_SITEMAP_DESC"
                       default="1"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="enable_schema"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_DESC"
                       default="1"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="enable_hreflang"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_HREFLANG_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_HREFLANG_DESC"
                       default="1"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <!-- FAQ Schema -->
                <field name="faq_schema_enabled"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_FAQ_SCHEMA_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_FAQ_SCHEMA_DESC"
                       default="1"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

            </fieldset>

            <!-- OpenGraph & Social Media Tab -->
            <fieldset name="opengraph" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_OPENGRAPH">

                <!-- OpenGraph Site Name -->
                <field name="og_site_name"
                       type="text"
                       label="PLG_SYSTEM_JOOMLABOOST_OG_SITE_NAME_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_OG_SITE_NAME_DESC"
                       default=""
                       hint="OffRoad Serbia"/>

                <!-- OpenGraph Default Image -->
                <field name="og_image"
                       type="media"
                       label="PLG_SYSTEM_JOOMLABOOST_OG_IMAGE_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_OG_IMAGE_DESC"
                       default=""
                       directory="images"/>

                <!-- Per-Article OpenGraph Override Notice -->
                <field name="og_override_note"
                       type="note"
                       label="📝 Per-Article OpenGraph Overrides"
                       description="To override OpenGraph meta tags for specific articles, use Joomla Custom Fields (com_fields). Create fields named: &lt;strong&gt;custom_og_image&lt;/strong&gt;, &lt;strong&gt;custom_og_title&lt;/strong&gt;, &lt;strong&gt;custom_og_description&lt;/strong&gt;. Priority: Custom Fields → Featured Image → Global Config."
                       class="alert alert-info"/>

                <!-- Organization Name (Fallback for og:site_name) -->
                <field name="org_name"
                       type="text"
                       label="PLG_SYSTEM_JOOMLABOOST_ORG_NAME_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_ORG_NAME_DESC"
                       default=""
                       hint="Organization Name"/>

                <!-- Organization Logo (Fallback for og:image) -->
                <field name="org_logo"
                       type="media"
                       label="PLG_SYSTEM_JOOMLABOOST_ORG_LOGO_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_ORG_LOGO_DESC"
                       default=""
                       directory="images"/>

                <!-- Schema.org Type Selection -->
                <field name="schema_type"
                       type="list"
                       label="Schema.org Organization Type"
                       description="Choose the type of schema for your organization. Auto-detect uses site characteristics, LocalBusiness includes geo/address data, Organization is generic."
                       default="auto">
                    <option value="auto">Auto-detect (recommended)</option>
                    <option value="localbusiness">LocalBusiness (for physical locations)</option>
                    <option value="organization">Organization (generic)</option>
                </field>

                <!-- LocalBusiness Geo Coordinates -->
                <field name="schema_latitude"
                       type="text"
                       label="Latitude"
                       description="Geographic latitude for LocalBusiness schema (e.g., 44.0165)"
                       default=""
                       showon="schema_type:localbusiness"
                       hint="44.0165"/>

                <field name="schema_longitude"
                       type="text"
                       label="Longitude"
                       description="Geographic longitude for LocalBusiness schema (e.g., 21.0059)"
                       default=""
                       showon="schema_type:localbusiness"
                       hint="21.0059"/>

                <!-- LocalBusiness Address -->
                <field name="schema_address_country"
                       type="text"
                       label="Country Code"
                       description="ISO 3166-1 alpha-2 country code (e.g., RS, US, GB)"
                       default=""
                       showon="schema_type:localbusiness"
                       hint="RS"/>

                <field name="schema_address_locality"
                       type="text"
                       label="City/Locality"
                       description="City or locality for LocalBusiness address"
                       default=""
                       showon="schema_type:localbusiness"
                       hint="Belgrade"/>

                <!-- LocalBusiness Service Details -->
                <field name="schema_price_range"
                       type="list"
                       label="Price Range"
                       description="Price range indicator for services"
                       default="$$"
                       showon="schema_type:localbusiness">
                    <option value="$">$ (Budget)</option>
                    <option value="$$">$$ (Moderate)</option>
                    <option value="$$$">$$$ (Expensive)</option>
                    <option value="$$$$">$$$$ (Very Expensive)</option>
                </field>

                <field name="schema_opening_hours"
                       type="text"
                       label="Opening Hours"
                       description="Business opening hours (e.g., Mo-Su 09:00-18:00)"
                       default="Mo-Su 09:00-18:00"
                       showon="schema_type:localbusiness"
                       hint="Mo-Su 09:00-18:00"/>

            </fieldset>

            <fieldset name="google" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_GOOGLE">

                <!-- Google Search Console Verification -->
                <field name="enable_google_verification"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_GOOGLE_VERIFICATION_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_GOOGLE_VERIFICATION_DESC"
                       default="0"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="gsc_verification_meta"
                       type="text"
                       label="PLG_SYSTEM_JOOMLABOOST_GSC_VERIFICATION_META_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_GSC_VERIFICATION_META_DESC"
                       default=""
                       showon="enable_google_verification:1"/>

                <field name="gsc_additional_html"
                       type="textarea"
                       label="PLG_SYSTEM_JOOMLABOOST_GSC_ADDITIONAL_HTML_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_GSC_ADDITIONAL_HTML_DESC"
                       default=""
                       rows="5"
                       cols="80"
                       showon="enable_google_verification:1"/>

                <!-- Google Analytics 4 -->
                <field name="enable_ga4"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_GA4_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_GA4_DESC"
                       default="0"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="ga4_measurement_id"
                       type="text"
                       label="PLG_SYSTEM_JOOMLABOOST_GA4_MEASUREMENT_ID_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_GA4_MEASUREMENT_ID_DESC"
                       default=""
                       hint="G-XXXXXXXXXX"
                       showon="enable_ga4:1"/>

                <!-- Google Tag Manager -->
                <field name="enable_gtm"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_GTM_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_GTM_DESC"
                       default="0"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="gtm_container_id"
                       type="text"
                       label="PLG_SYSTEM_JOOMLABOOST_GTM_CONTAINER_ID_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_GTM_CONTAINER_ID_DESC"
                       default=""
                       hint="GTM-XXXXXXX"
                       showon="enable_gtm:1"/>

            </fieldset>

            <fieldset name="facebook" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_FACEBOOK">

                <!-- Meta Pixel (Facebook Pixel) -->
                <field name="enable_meta_pixel"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_DESC"
                       default="0"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="meta_pixel_id"
                       type="text"
                       label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_ID_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_ID_DESC"
                       default=""
                       hint="123456789012345"
                       showon="enable_meta_pixel:1"/>

                <!-- Meta Pixel Custom Events -->
                <field name="meta_pixel_events_header"
                       type="note"
                       label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_EVENTS_HEADER"
                       description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_EVENTS_HEADER_DESC"
                       showon="enable_meta_pixel:1"/>

                <field name="meta_pixel_track_purchase"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_PURCHASE_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_PURCHASE_DESC"
                       default="0"
                       class="btn-group btn-group-yesno"
                       showon="enable_meta_pixel:1">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="meta_pixel_track_add_to_cart"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_ADD_TO_CART_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_ADD_TO_CART_DESC"
                       default="0"
                       class="btn-group btn-group-yesno"
                       showon="enable_meta_pixel:1">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="meta_pixel_track_contact"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_CONTACT_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_CONTACT_DESC"
                       default="0"
                       class="btn-group btn-group-yesno"
                       showon="enable_meta_pixel:1">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="meta_pixel_track_lead"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_LEAD_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_META_PIXEL_TRACK_LEAD_DESC"
                       default="0"
                       class="btn-group btn-group-yesno"
                       showon="enable_meta_pixel:1">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

            </fieldset>

            <fieldset name="performance" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_PERFORMANCE">

                <field name="enable_caching"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_CACHING_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_CACHING_DESC"
                       default="1"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="cache_ttl"
                       type="number"
                       label="PLG_SYSTEM_JOOMLABOOST_CACHE_TTL_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_CACHE_TTL_DESC"
                       default="3600"
                       min="60"
                       max="86400"
                       showon="enable_caching:1"/>

            </fieldset>

            <fieldset name="debug" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_DEBUG">

                <field name="debug_mode"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_DEBUG_MODE_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_DEBUG_MODE_DESC"
                       default="0"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="debug_wrap_markers"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_DEBUG_WRAP_MARKERS_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_DEBUG_WRAP_MARKERS_DESC"
                       default="0"
                       class="btn-group btn-group-yesno"
                       showon="debug_mode:1">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

                <field name="show_staging_badge"
                       type="radio"
                       label="PLG_SYSTEM_JOOMLABOOST_STAGING_BADGE_LABEL"
                       description="PLG_SYSTEM_JOOMLABOOST_STAGING_BADGE_DESC"
                       default="0"
                       class="btn-group btn-group-yesno">
                    <option value="1">JYES</option>
                    <option value="0">JNO</option>
                </field>

            </fieldset>
        </fields>
    </config>

    <updateservers>
        <server type="extension" priority="1" name="JoomlaBoost Update Server">
            https://updates.joomlaboost.com/joomlaboost.xml
        </server>
    </updateservers>
</extension>
