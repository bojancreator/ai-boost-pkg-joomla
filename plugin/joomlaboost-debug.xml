<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>JoomlaBoost Debug</name>
    <author>BojanCreator</author>
    <creationDate>September 2025</creationDate>
    <copyright>Copyright (C) 2025 BojanCreator. All rights reserved.</copyright>
    <license>GPL v2.0 or later</license>
    <authorEmail>admin@domain.com</authorEmail>
    <authorUrl>https://github.com/bojancreator/JoomlaBoost</authorUrl>
    <version>0.1.17-debug</version>
    <description>JoomlaBoost Debug Plugin - System plugin for SEO optimization with extensive logging</description>

    <files>
        <filename plugin="joomlaboostdebug">joomlaboost-debug.php</filename>
    </files>

    <config>
        <fields name="params">
            <fieldset name="basic">
                <field name="enabled" type="radio" default="1" label="Enable Plugin" description="Enable or disable the plugin">
                    <option value="0">Disabled</option>
                    <option value="1">Enabled</option>
                </field>
                <field name="debug_mode" type="radio" default="1" label="Debug Mode" description="Enable debug logging">
                    <option value="0">Disabled</option>
                    <option value="1">Enabled</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
