<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
  <name>PLG_SYSTEM_JOOMLABOOST</name>
  <author>JoomlaBoost Team</author>
  <creationDate>April 29, 2026 11:08</creationDate>
  <copyright>(C) 2025 JoomlaBoost. All rights reserved.</copyright>
  <license>GNU General Public License version 2 or later</license>
  <authorEmail>info@joomlaboost.com</authorEmail>
  <authorUrl>https://joomlaboost.com</authorUrl>
  <version>0.24.0</version>
  <description>PLG_SYSTEM_JOOMLABOOST_XML_DESCRIPTION</description>
  <!-- System Requirements -->
  <php_minimum>8.1.0</php_minimum>
  <joomla_minimum>4.0.0</joomla_minimum>
  <joomla_maximum>6.9999.9999</joomla_maximum>
  <scriptfile>script.php</scriptfile>
  <files>
    <filename plugin="joomlaboost">joomlaboost.php</filename>
    <folder>language</folder>
    <folder>src</folder>
    <folder>media</folder>
    <folder>sql</folder>
  </files>
  <!-- Custom Form Fields -->
  <addonfields path="src/Field">
    <field>MultiLangTextField</field>
    <field>MultiLangTextarea</field>
    <field>MultiLangFaqField</field>
    <field>MultiLangParamsTextField</field>
    <field>MultiLangParamsTextarea</field>
  </addonfields>
  <!-- Media Assets -->
  <media folder="media" destination="plg_system_joomlaboost">
    <folder>js</folder>
    <folder>css</folder>
    <filename>admin.css</filename>
    <filename>multilang-fields.css</filename>
    <filename>joomla.asset.json</filename>
  </media>
  <languages>
    <language tag="en-GB">language/en-GB/plg_system_joomlaboost.ini</language>
    <language tag="en-GB">language/en-GB/plg_system_joomlaboost.sys.ini</language>
    <language tag="sr-RS">language/sr-RS/plg_system_joomlaboost.ini</language>
    <language tag="sr-RS">language/sr-RS/plg_system_joomlaboost.sys.ini</language>
    <language tag="de-DE">language/de-DE/plg_system_joomlaboost.ini</language>
    <language tag="de-DE">language/de-DE/plg_system_joomlaboost.sys.ini</language>
    <language tag="es-ES">language/es-ES/plg_system_joomlaboost.ini</language>
    <language tag="es-ES">language/es-ES/plg_system_joomlaboost.sys.ini</language>
    <language tag="fr-FR">language/fr-FR/plg_system_joomlaboost.ini</language>
    <language tag="fr-FR">language/fr-FR/plg_system_joomlaboost.sys.ini</language>
    <language tag="it-IT">language/it-IT/plg_system_joomlaboost.ini</language>
    <language tag="it-IT">language/it-IT/plg_system_joomlaboost.sys.ini</language>
    <language tag="ru-RU">language/ru-RU/plg_system_joomlaboost.ini</language>
    <language tag="ru-RU">language/ru-RU/plg_system_joomlaboost.sys.ini</language>
    <language tag="pt-BR">language/pt-BR/plg_system_joomlaboost.ini</language>
    <language tag="pt-BR">language/pt-BR/plg_system_joomlaboost.sys.ini</language>
    <language tag="zh-CN">language/zh-CN/plg_system_joomlaboost.ini</language>
    <language tag="zh-CN">language/zh-CN/plg_system_joomlaboost.sys.ini</language>
    <language tag="ar-AA">language/ar-AA/plg_system_joomlaboost.ini</language>
    <language tag="ar-AA">language/ar-AA/plg_system_joomlaboost.sys.ini</language>
    <language tag="ja-JP">language/ja-JP/plg_system_joomlaboost.ini</language>
    <language tag="ja-JP">language/ja-JP/plg_system_joomlaboost.sys.ini</language>
  </languages>
  <config>
    <fields name="params">

      <!-- ════════════════════════════════════════════════════════════════════ -->
      <!-- TAB 1: PLUGIN — Quick Setup + Interface Mode + Domain/Robots       -->
      <!-- ════════════════════════════════════════════════════════════════════ -->
      <fieldset name="basic" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_BASIC">

        <!-- ── QUICK SETUP ─────────────────────────────────────────────────── -->
        <field name="separator_preset" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_PRESET" class="text-success" />
        <field name="vertical_preset" type="list" label="PLG_SYSTEM_JOOMLABOOST_VERTICAL_PRESET_LABEL" description="PLG_SYSTEM_JOOMLABOOST_VERTICAL_PRESET_DESC" default="">
          <option value="">PLG_SYSTEM_JOOMLABOOST_OPT_PRESET_SELECT</option>
          <option value="hotel">PLG_SYSTEM_JOOMLABOOST_OPT_PRESET_HOTEL</option>
          <option value="restaurant">PLG_SYSTEM_JOOMLABOOST_OPT_PRESET_RESTAURANT</option>
          <option value="blog">PLG_SYSTEM_JOOMLABOOST_OPT_PRESET_BLOG</option>
          <option value="ecommerce">PLG_SYSTEM_JOOMLABOOST_OPT_PRESET_ECOMMERCE</option>
          <option value="generic">PLG_SYSTEM_JOOMLABOOST_OPT_PRESET_GENERIC</option>
        </field>
        <field name="vertical_preset_apply" type="radio" label="PLG_SYSTEM_JOOMLABOOST_VERTICAL_PRESET_APPLY_LABEL" description="PLG_SYSTEM_JOOMLABOOST_VERTICAL_PRESET_APPLY_DESC" default="0" class="btn-group btn-group-yesno" showon="vertical_preset!:">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="vertical_preset_last" type="hidden" default="" />
        <field name="vertical_preset_last_at" type="hidden" default="" />
        <field name="show_advanced_options" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SHOW_ADVANCED_OPTIONS_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SHOW_ADVANCED_OPTIONS_DESC" default="0" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>

        <!-- ── DOMAIN AND ENVIRONMENT ─────────────────────────────────────────── -->
        <field name="separator_domain" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_DOMAIN" class="text" />
        <field name="auto_domain_detection" type="radio" label="PLG_SYSTEM_JOOMLABOOST_AUTO_DOMAIN_DETECTION_LABEL" description="PLG_SYSTEM_JOOMLABOOST_AUTO_DOMAIN_DETECTION_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="manual_domain" type="url" label="PLG_SYSTEM_JOOMLABOOST_MANUAL_DOMAIN_LABEL" description="PLG_SYSTEM_JOOMLABOOST_MANUAL_DOMAIN_DESC" default="" showon="auto_domain_detection:0" />

        <!-- ── ROBOTS.TXT ───────────────────────────────────────────────────── -->
        <field name="separator_robots" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_ROBOTS" class="text" />
        <field name="enable_robots" type="radio" label="PLG_SYSTEM_JOOMLABOOST_ROBOTS_LABEL" description="PLG_SYSTEM_JOOMLABOOST_ROBOTS_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="robots_auto_sync" type="radio" label="PLG_SYSTEM_JOOMLABOOST_ROBOTS_AUTO_SYNC_LABEL" description="PLG_SYSTEM_JOOMLABOOST_ROBOTS_AUTO_SYNC_DESC" default="1" class="btn-group btn-group-yesno" showon="enable_robots:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>

      </fieldset>

      <!-- ════════════════════════════════════════════════════════════════════ -->
      <!-- TAB 2: ORGANIZATION — Identity, Contact, Social, Location          -->
      <!-- (moved before Schema.org — "who you are" before "how you appear")  -->
      <!-- ════════════════════════════════════════════════════════════════════ -->
      <fieldset name="organization" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_ORGANIZATION">

        <!-- Organization Name, Description, Logo per installed language -->
        <!-- Injected dynamically by onContentPrepareForm: org_name_{code}, org_description_{code}, org_logo_{code} -->

        <!-- ── CONTACT ──────────────────────────────────────────────────────── -->
        <field name="separator_contact" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_CONTACT" class="text" />
        <field name="schema_url" type="url" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_URL_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_URL_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_URL_EXAMPLE" />
        <field name="schema_email" type="email" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_EMAIL_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_EMAIL_DESC" default="" />
        <field name="schema_phone" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_PHONE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_PHONE_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_PHONE_EXAMPLE" />

        <!-- ── SOCIAL MEDIA LINKS (sameAs schema) ──────────────────────────── -->
        <field name="schema_social_spacer" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_SOCIAL" class="text-primary" />
        <field name="schema_social_facebook" type="url" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_FACEBOOK_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_FACEBOOK_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_SOCIAL_FACEBOOK" />
        <field name="schema_social_instagram" type="url" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_INSTAGRAM_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_INSTAGRAM_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_SOCIAL_INSTAGRAM" />
        <field name="schema_social_youtube" type="url" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_YOUTUBE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_YOUTUBE_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_SOCIAL_YOUTUBE" />
        <field name="schema_social_twitter" type="url" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_TWITTER_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_TWITTER_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_SOCIAL_TWITTER" />
        <field name="schema_social_linkedin" type="url" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_LINKEDIN_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_SOCIAL_LINKEDIN_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_SOCIAL_LINKEDIN" />

        <!-- ── LOCATION ─────────────────────────────────────────────────────── -->
        <field name="separator_location" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_LOCATION" class="text-warning" />
        <field name="schema_address_country" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_ADDRESS_COUNTRY_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_ADDRESS_COUNTRY_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_COUNTRY_CODE" />
        <field name="schema_address_zip" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_ADDRESS_ZIP_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_ADDRESS_ZIP_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_ZIP_CODE" />
        <!-- City/Locality + Street per installed language -->
        <!-- Injected dynamically by onContentPrepareForm: schema_address_locality_{code}, schema_address_street_{code} -->
        <field name="separator_address_multilang" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_ADDRESS_MULTILANG" class="text-info" />
        <field name="schema_latitude" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_LATITUDE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_LATITUDE_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_LATITUDE" />
        <field name="schema_longitude" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_LONGITUDE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_LONGITUDE_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_LONGITUDE" />

        <!-- ── GUEST RATINGS (ADVANCED) ─────────────────────────────────────── -->
        <field name="separator_rating" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_RATING" class="text" showon="show_advanced_options:1" />
        <field name="schema_rating_value" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_VALUE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_VALUE_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_RATING_VALUE" showon="show_advanced_options:1" />
        <field name="schema_rating_count" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_COUNT_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_COUNT_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_RATING_COUNT" showon="show_advanced_options:1" />
        <field name="schema_rating_best" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_BEST_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_BEST_DESC" default="5" hint="PLG_SYSTEM_JOOMLABOOST_HINT_RATING_BEST" showon="show_advanced_options:1" />
        <field name="schema_rating_worst" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_WORST_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_WORST_DESC" default="1" hint="PLG_SYSTEM_JOOMLABOOST_HINT_RATING_WORST" showon="show_advanced_options:1" />
        <field name="schema_rating_source" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_SOURCE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_RATING_SOURCE_DESC" default="" hint="PLG_SYSTEM_JOOMLABOOST_HINT_RATING_SOURCE" showon="show_advanced_options:1" />

      </fieldset>

      <!-- ════════════════════════════════════════════════════════════════════ -->
      <!-- TAB 3: SCHEMA.ORG — Structured Data, FAQ, Events                  -->
      <!-- ════════════════════════════════════════════════════════════════════ -->
      <fieldset name="schema" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_SCHEMA">

        <field name="enable_schema" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>

        <!-- ── SCHEMA TYPE ──────────────────────────────────────────────────── -->
        <field name="schema_type" type="list" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_TYPE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_TYPE_DESC" default="auto" showon="enable_schema:1">
          <option value="auto">PLG_SYSTEM_JOOMLABOOST_OPT_SCHEMA_AUTO</option>
          <option value="organization">PLG_SYSTEM_JOOMLABOOST_OPT_SCHEMA_ORGANIZATION</option>
          <option value="localbusiness">PLG_SYSTEM_JOOMLABOOST_OPT_SCHEMA_LOCALBUSINESS</option>
          <option value="hotel">PLG_SYSTEM_JOOMLABOOST_OPT_SCHEMA_HOTEL</option>
        </field>

        <!-- ── HOTEL-SPECIFIC FIELDS ───────────────────────────────────────── -->
        <field name="separator_hotel" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_HOTEL" class="text-info" showon="enable_schema:1[AND]schema_type:hotel" />
        <field name="schema_hotel_star_rating" type="list" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_HOTEL_STAR_RATING_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_HOTEL_STAR_RATING_DESC" default="3" showon="enable_schema:1[AND]schema_type:hotel">
          <option value="1">PLG_SYSTEM_JOOMLABOOST_OPT_STAR_1</option>
          <option value="2">PLG_SYSTEM_JOOMLABOOST_OPT_STAR_2</option>
          <option value="3">PLG_SYSTEM_JOOMLABOOST_OPT_STAR_3</option>
          <option value="4">PLG_SYSTEM_JOOMLABOOST_OPT_STAR_4</option>
          <option value="5">PLG_SYSTEM_JOOMLABOOST_OPT_STAR_5</option>
        </field>
        <field name="schema_hotel_checkin_time" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_HOTEL_CHECKIN_TIME_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_HOTEL_CHECKIN_TIME_DESC" default="14:00" showon="enable_schema:1[AND]schema_type:hotel" hint="PLG_SYSTEM_JOOMLABOOST_HINT_CHECKIN_TIME" />
        <field name="schema_hotel_checkout_time" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_HOTEL_CHECKOUT_TIME_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_HOTEL_CHECKOUT_TIME_DESC" default="12:00" showon="enable_schema:1[AND]schema_type:hotel" hint="PLG_SYSTEM_JOOMLABOOST_HINT_CHECKOUT_TIME" />
        <field name="schema_hotel_pets_allowed" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_HOTEL_PETS_ALLOWED_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_HOTEL_PETS_ALLOWED_DESC" default="0" class="btn-group btn-group-yesno" showon="enable_schema:1[AND]schema_type:hotel">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>

        <!-- ── LOCALBUSINESS / HOTEL SERVICE DETAILS ───────────────────────── -->
        <field name="separator_business" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_BUSINESS" class="text-info" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" />
        <field name="schema_price_range" type="list" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_PRICE_RANGE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_PRICE_RANGE_DESC" default="$$" showon="enable_schema:1[AND]schema_type:localbusiness,hotel">
          <option value="$">PLG_SYSTEM_JOOMLABOOST_OPT_PRICE_BUDGET</option>
          <option value="$$">PLG_SYSTEM_JOOMLABOOST_OPT_PRICE_MODERATE</option>
          <option value="$$$">PLG_SYSTEM_JOOMLABOOST_OPT_PRICE_EXPENSIVE</option>
          <option value="$$$$">PLG_SYSTEM_JOOMLABOOST_OPT_PRICE_VERY_EXPENSIVE</option>
        </field>
        <field name="schema_opening_hours" type="text" label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_OPENING_HOURS_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_OPENING_HOURS_DESC" default="Mo-Su 09:00-18:00" showon="enable_schema:1[AND]schema_type:localbusiness,hotel" hint="PLG_SYSTEM_JOOMLABOOST_HINT_OPENING_HOURS" />

        <!-- ── FAQ SCHEMA ───────────────────────────────────────────────────── -->
        <field name="separator_faq" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_FAQ" class="text" showon="enable_schema:1" />
        <field name="faq_auto_detect" type="radio" label="PLG_SYSTEM_JOOMLABOOST_FAQ_AUTO_DETECT_LABEL" description="PLG_SYSTEM_JOOMLABOOST_FAQ_AUTO_DETECT_DESC" default="1" class="btn-group btn-group-yesno" showon="enable_schema:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>

        <!-- ── MANUAL FAQ (ADVANCED) ────────────────────────────────────────── -->
        <field name="separator_qa_management" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_MANUAL_FAQ" class="text-primary" showon="enable_schema:1,show_advanced_options:1" />
        <field name="enable_manual_faqs" type="radio" label="PLG_SYSTEM_JOOMLABOOST_ENABLE_MANUAL_FAQS_LABEL" description="PLG_SYSTEM_JOOMLABOOST_ENABLE_MANUAL_FAQS_DESC" default="0" class="btn-group btn-group-yesno" showon="enable_schema:1,show_advanced_options:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="manual_faq_scope" type="list" label="PLG_SYSTEM_JOOMLABOOST_MANUAL_FAQ_SCOPE_LABEL" description="PLG_SYSTEM_JOOMLABOOST_MANUAL_FAQ_SCOPE_DESC" default="fallback_all" showon="enable_schema:1[AND]enable_manual_faqs:1,show_advanced_options:1">
          <option value="fallback_all">PLG_SYSTEM_JOOMLABOOST_OPT_FAQ_SCOPE_FALLBACK_ALL</option>
          <option value="always_all">PLG_SYSTEM_JOOMLABOOST_OPT_FAQ_SCOPE_ALWAYS_ALL</option>
          <option value="fallback_home">PLG_SYSTEM_JOOMLABOOST_OPT_FAQ_SCOPE_FALLBACK_HOME</option>
          <option value="always_home">PLG_SYSTEM_JOOMLABOOST_OPT_FAQ_SCOPE_ALWAYS_HOME</option>
          <option value="disabled">PLG_SYSTEM_JOOMLABOOST_OPT_FAQ_SCOPE_DISABLED</option>
        </field>
        <!-- Manual FAQ per installed language -->
        <!-- Injected dynamically by onContentPrepareForm: manual_faqs_{code} -->
        <field name="faq_json_help" type="note" label="PLG_SYSTEM_JOOMLABOOST_FAQ_JSON_HELP_LABEL" description="PLG_SYSTEM_JOOMLABOOST_FAQ_JSON_HELP_DESC" class="alert alert-info" showon="enable_schema:1[AND]enable_manual_faqs:1,show_advanced_options:1" />

        <!-- ── EVENT SCHEMA ─────────────────────────────────────────────────── -->
        <field name="separator_events" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_EVENTS" class="text" showon="enable_schema:1" />
        <field name="schema_events_enabled" type="radio"
               label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_EVENTS_ENABLED_LABEL"
               description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_EVENTS_ENABLED_DESC"
               default="0"
               class="btn-group btn-group-yesno"
               showon="enable_schema:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <!-- Events JSON per installed language -->
        <!-- Injected dynamically by onContentPrepareForm: schema_events_{code} -->
        <field name="schema_events_help" type="note"
               label="PLG_SYSTEM_JOOMLABOOST_SCHEMA_EVENTS_HELP_LABEL"
               description="PLG_SYSTEM_JOOMLABOOST_SCHEMA_EVENTS_HELP_DESC"
               class="alert alert-info"
               showon="enable_schema:1,schema_events_enabled:1" />

      </fieldset>

      <!-- ════════════════════════════════════════════════════════════════════ -->
      <!-- TAB 4: SITEMAP — XML Sitemap + Hreflang (moved here from Plugin)   -->
      <!-- ════════════════════════════════════════════════════════════════════ -->
      <fieldset name="sitemap" label="PLG_SYSTEM_JOOMLABOOST_FIELDSET_SITEMAP">

        <!-- ── HREFLANG (moved from Plugin tab — belongs with Sitemap) ───────── -->
        <field name="enable_hreflang" type="radio" label="PLG_SYSTEM_JOOMLABOOST_HREFLANG_LABEL" description="PLG_SYSTEM_JOOMLABOOST_HREFLANG_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>

        <field name="separator_sitemap_main" type="spacer" label="PLG_SYSTEM_JOOMLABOOST_SEP_SITEMAP_MAIN" class="text" />
        <field name="enable_sitemap" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SITEMAP_LABEL" description="PLG_SYSTEM_JOOMLABOOST_SITEMAP_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>

        <!-- ── WHAT TO INCLUDE ──────────────────────────────────────────────── -->
        <field name="sitemap_include_articles" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SITEMAP_INCLUDE_ARTICLES_LABEL" default="1" class="btn-group btn-group-yesno" showon="enable_sitemap:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="sitemap_include_categories" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SITEMAP_INCLUDE_CATEGORIES_LABEL" default="1" class="btn-group btn-group-yesno" showon="enable_sitemap:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="sitemap_include_menu" type="radio" label="PLG_SYSTEM_JOOMLABOOST_SITEMAP_INCLUDE_MENU_LABEL" default="1" class="btn-group btn-group-yesno" showon="enable_sitemap:1">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>

        <!-- ── MENU OPTIONS (ADVANCED) ──────────────────────────────────────── -->
