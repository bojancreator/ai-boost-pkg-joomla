{
  "name": "joomlaboost/joomlaboost",
  "description": "AI Boost for Joomla — universal SEO & AEO plugin source and workspace.",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "AiBoost\\Lib\\": "component/lib/src/",
      "AiBoost\\Plugin\\System\\AiBoostAeo\\": "component/plugins/system/aiboost_aeo/src/",
      "AiBoost\\Plugin\\System\\AiBoostSchema\\": "component/plugins/system/aiboost_schema/src/",
      "AiBoost\\Plugin\\System\\AiBoostSitemap\\": "component/plugins/system/aiboost_sitemap/src/",
      "AiBoost\\Plugin\\System\\AiBoostSocial\\": "component/plugins/system/aiboost_social/src/",
      "AiBoost\\Plugin\\System\\AiBoostIntFalang\\": "component/plugins/system/aiboost_int_falang/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AiBoost\\Tests\\": "component/tests/"
    }
  },
  "scripts": {
    "test":    "@php plugin/src/plugins/system/joomlaboost/tests/canonical-regex-test.php",
    "phpunit": "vendor/bin/phpunit",
    "phpcs":   "phpcs --standard=phpcs.xml",
    "phpstan": "phpstan analyse --configuration=phpstan.neon --no-progress"
  }
}
