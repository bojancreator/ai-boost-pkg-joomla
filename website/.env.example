# Google Search Console — HTML meta tag verification
# Get this from: https://search.google.com/search-console
# Add your property (URL prefix: https://aiboostnow.com)
# Choose "HTML tag" verification method and copy the content= value
VITE_GOOGLE_SITE_VERIFICATION=

# IndexNow ping behaviour (runs automatically after `pnpm build`)
# By default the ping is skipped unless running in CI (GitHub Actions sets CI=true).
# INDEXNOW_SKIP=1   — always skip (e.g. if you want to disable it in CI too)
# INDEXNOW_FORCE=1  — always run even outside CI (e.g. for a one-off manual ping)
INDEXNOW_SKIP=
INDEXNOW_FORCE=
