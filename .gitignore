# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Local test-plugin downloads and their API/license keys — NEVER commit.
# The `.api_keys.txt` credentials file lives here (the old narrow rule only
# matched `api_keys.txt`, missing the dot-prefixed name). Already-tracked
# fixture ZIPs stay in git; new files here are ignored — use `git add -f` to
# deliberately track one.
/test-plugins/

# PHPUnit cache (regenerated automatically on each run)
.phpunit.result.cache

# Run artifacts (smoke screenshots, qa-reports, UI audits — all regenerated per run)
/artifacts/

# Python bytecode cache
scripts/__pycache__/

# Test site credentials (real admin passwords) — use test_sajtovi.example.md as template
/test_sajtovi.md

# Local secrets / env — NEVER commit (DB roots, phpMyAdmin, API keys)
.env
.env.*
CREDENTIALS.local.md

# Deliverables (ZIP-ovi, PDF-ovi, marketing materijali — ne idu u git)
/deliverables/
# Exception: text reports and docs in deliverables/docs/ are tracked
!/deliverables/docs/
!/deliverables/docs/*.md
# Exception: SDK template bridge for third-party integration developers
!/deliverables/integrations/
!/deliverables/integrations/**

# Generated OG images — regenerated fresh by `prebuild` on every `pnpm build`
website/public/og/
