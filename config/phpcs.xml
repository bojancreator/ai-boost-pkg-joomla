<?xml version="1.0"?>
<ruleset name="JoomlaBoost QA">
  <description>PSR-12 and core rules for Joomla/PHP first-party code.</description>
  
  <!-- Fajlovi će biti prosleđeni kao argumenti iz composer skripte -->
  
  <rule ref="PSR12">
    <!-- Joomla pluginovi često nemaju namespace; isključi ovo pravilo -->
    <exclude name="PSR1.Classes.ClassDeclaration.MissingNamespace"/>
    <!-- Joomla pluginovi imaju side effects; isključi ovo upozorenje -->
    <exclude name="PSR1.Files.SideEffects"/>
    <!-- Dugačke linije su OK; možda imamo dugačke SQL upite ili URL-ove -->
    <exclude name="Generic.Files.LineLength"/>
  </rule>
  
  <arg name="basepath" value="."/>
  
  <!-- Isključi fajlove koji nisu produkcijski -->
  <exclude-pattern>vendor/*</exclude-pattern>
  <exclude-pattern>plugin/joomlaboost-*.php</exclude-pattern>
  <exclude-pattern>*_refactored.php</exclude-pattern>
  <exclude-pattern>*/test/*</exclude-pattern>
  <exclude-pattern>*/tests/*</exclude-pattern>
  
    <!-- Exclude vendor and build directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/tools/__build/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/stubs/*</exclude-pattern>
    
    <!-- Joomla installer script uses plg prefix (convention) -->
    <rule ref="Squiz.Classes.ValidClassName">
        <exclude-pattern>*/script.php</exclude-pattern>
    </rule>
</ruleset>
