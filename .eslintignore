# Exclude vendor and build artifacts from JS/TS linting
vendor/
node_modules/
build/
**/vendor/**
**/node_modules/**
**/build/**
/vendor/**
/node_modules/**
/build/**
/tools/**
tools/__inspect_external_plugin/**
# Ignore third-party and inspection/build artifacts
archive/
tools/__build/
tools/__inspect_*/
tools/**
/archive/**
# Anchor from repo root as well (some analyzers resolve absolute paths)
/.eslintignore
/tools/**
/archive/**
/vendor/**
/node_modules/**
/build/**
# Generated or packaged assets
**/*.min.js
**/dist/**
/**/*.min.js
/**/dist/**
