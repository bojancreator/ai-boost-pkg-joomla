<?xml version="1.0" encoding="utf-8"?>
<extension version="3.0" type="plugin" group="system" method="upgrade">
    <name>PLG_SYSTEM_FORSEO</name>
    <author>Yannick Gaultier - Weeblr llc</author>
    <creationDate>2026-01-30</creationDate>
    <copyright>Copyright Weeblr llc - 2020 - 2026</copyright>
    <license>GNU General Public License version 3; see LICENSE.md</license>
    <authorEmail>contact@weeblr.com</authorEmail>
    <authorUrl>https://weeblr.com/</authorUrl>
    <version>6.10.1.2660</version>
    <description>PLG_SYSTEM_FORSEO_XML_DESCRIPTION</description>
    <files>
        <folder>language</folder>
        <folder>platform</folder>
        <folder>vendor</folder>
        <folder>sql</folder>
        <filename plugin="forseo">forseo.php</filename>
        <filename>boot.php</filename>
        <filename>defines.php</filename>
        <filename>app_defines.php</filename>
        <filename>LICENSE.md</filename>
    </files>
    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/base/install.sql</file>
        </sql>
    </install>
    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/base/uninstall.sql</file>
        </sql>
    </uninstall>
    <update>
        <schemas>
            <schemapath type="mysql">sql/updates</schemapath>
        </schemas>
    </update>
    <media folder="media" destination="com_forseo">
        <folder>vendor</folder>
        <folder>cache</folder>
    </media>
</extension>
